    <mxCell id="sub_n1_1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="&lt;b&gt;[Usuario]&lt;/b&gt;&lt;div&gt;&lt;br&gt;Accede a /subscriptions, frontend carga planes y suscripcion activa en paralelo&lt;/div&gt;" vertex="1">

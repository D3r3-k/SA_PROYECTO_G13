# General
NODE_ENV=development

# Redis
REDIS_URL=redis://redis:6379/0
NOTIFICATION_QUEUE_NAME=notification:queue

# Identity Database
IDENTITY_DB_NAME=identity_db
IDENTITY_DB_USER=identity_user
IDENTITY_DB_PASSWORD=identity_password
IDENTITY_DB_HOST=identity-db
IDENTITY_DB_PORT=5432
IDENTITY_DB_SSL=false

# Subscription Database
SUBSCRIPTION_DB_NAME=subscription_db
SUBSCRIPTION_DB_USER=sa_sub_user
SUBSCRIPTION_DB_PASSWORD=sa_sub_pass
SUBSCRIPTION_DB_HOST=subscription-db
SUBSCRIPTION_DB_PORT=5432
SUBSCRIPTION_DATABASE_URL=postgresql://sa_sub_user:sa_sub_pass@subscription-db:5432/subscription_db

# JWT
JWT_SECRET=CAMBIAR_JWT_SECRET_LOCAL
JWT_EXPIRES_IN=1d

# Identity Service
IDENTITY_GRPC_HOST=0.0.0.0
IDENTITY_GRPC_PORT=50051

# FX Service
FX_GRPC_PORT=50052
FX_CACHE_TTL=3600
FX_API_BASE_URL=https://api.frankfurter.dev/v2

# Subscription Service
SUBSCRIPTION_GRPC_PORT=50053

# Notification Service
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@quetxaltv.com
SMTP_STARTTLS=true

# API Gateway
API_GATEWAY_PORT=3000
FRONTEND_URL=http://localhost:8080
API_GATEWAY_UPSTREAM=api-gateway:3000
COOKIE_NAME=access_token
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
IDENTITY_GRPC_URL=identity-service:50051
FX_GRPC_URL=fx-service:50052
SUBSCRIPTION_GRPC_URL=subscription-service:50053
CATALOG_GRPC_URL=catalog-service:50055
ENGAGEMENT_GRPC_URL=engagement-service:50056
PAYMENT_GRPC_URL=payment-gateway-service:50057

# Catalog Service
CATALOG_DB_NAME=catalog_db
CATALOG_DB_USER=catalog_user
CATALOG_DB_PASSWORD=catalog_password
CATALOG_GRPC_PORT=50055
CATALOG_DATABASE_URL=postgresql://catalog_user:catalog_password@catalog-db:5432/catalog_db
GCS_PROJECT_ID=sa-derek-proyecto
GCS_BUCKET_NAME=qx-media-sa-derek-proyecto
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/gcp-service-account.json
GCS_SIGNED_UPLOAD_EXPIRES_MINUTES=15
GCS_SIGNED_READ_EXPIRES_MINUTES=60
GCS_ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
GCS_ALLOWED_VIDEO_TYPES=video/mp4,video/webm
GCS_MAX_IMAGE_MB=10
GCS_MAX_VIDEO_MB=1024

# Archive seed data
ARCHIVE_METADATA_BASE_URL=https://archive.org/metadata
ARCHIVE_DOWNLOAD_BASE_URL=https://archive.org/download
ARCHIVE_IMAGE_BASE_URL=https://archive.org/services/img
ARCHIVE_MOVIE_TARGET=10
ARCHIVE_SERIES_TARGET=20
ARCHIVE_SERIES_EPISODE_LIMIT=20
ARCHIVE_MOVIE_IDENTIFIERS=charlie-chaplin-the-champion-1915,charliechaplin_theimmigrant_20190819,night_of_the_living_dead,TheGeneral,Nosferatu1922
ARCHIVE_SERIES_IDENTIFIERS=BarbecueForTwo1960,Popeye_forPresident,popeye-meets-ali-baba-1937,PopeyePopeyeTheSailorMeetsSindbadTheSailor1936,PopeyeAncientFistory,popeye-little-sweepea-1936,popeye-greek-mirthology-1954,popeye-i-dont-scare-1956,popeye-spree-lunch-1957
ARCHIVE_SERIES_EPISODE_IDENTIFIERS=
ARCHIVE_SERIES_TITLE=Serie Internet Archive
ARCHIVE_ALLOW_FALLBACK=false

# Engagement Service
ENGAGEMENT_DB_NAME=engagement_db
ENGAGEMENT_DB_USER=engagement_user
ENGAGEMENT_DB_PASSWORD=engagement_password
ENGAGEMENT_GRPC_PORT=50056
ENGAGEMENT_DATABASE_URL=postgresql://engagement_user:engagement_password@engagement-db:5432/engagement_db

# Payment Service
PAYMENT_GRPC_PORT=50057
PAYMENT_PROVIDER_NAME=QuetxalPay Sandbox
PAYMENT_APPROVAL_DELAY_MS=500

# Web
WEB_PORT=8080

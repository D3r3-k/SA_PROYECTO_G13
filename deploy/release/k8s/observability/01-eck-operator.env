# ECK Operator 3.4.0 — aplicado desde el manifiesto oficial con version fijada.
# El step deploy-observability del workflow descarga este manifiesto y lo aplica
# via: kubectl apply -f deploy/release/k8s/observability/01-eck-operator.yml
#
# Este archivo es un marcador de version; el manifiesto real se descarga en CI
# para garantizar integridad. La URL esta fijada a 3.4.0:
#   https://download.elastic.co/downloads/eck/3.4.0/crds.yaml
#   https://download.elastic.co/downloads/eck/3.4.0/operator.yaml
#
# El job deploy-observability aplica ambos archivos en orden.
ECK_VERSION: "3.4.0"

# Copiar a infra/.env.gcp y completar con tus datos reales de GCP.
# No subir infra/.env.gcp al repositorio.

# =========================
# General
# =========================
NODE_ENV=production
FRONTEND_URL=http://localhost:8080

# =========================
# Redis local en Docker
# =========================
REDIS_URL=redis://redis:6379/0
NOTIFICATION_QUEUE_NAME=notification:queue

# =========================
# JWT / Cookies
# =========================
JWT_SECRET=CAMBIAR_POR_UN_SECRETO_LARGO
JWT_EXPIRES_IN=1d
COOKIE_NAME=access_token
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# =========================
# Puertos internos gRPC
# =========================
IDENTITY_GRPC_HOST=0.0.0.0
IDENTITY_GRPC_PORT=50051
FX_GRPC_PORT=50052
SUBSCRIPTION_GRPC_PORT=50053
NOTIFICATION_GRPC_PORT=50054
CATALOG_GRPC_PORT=50055
ENGAGEMENT_GRPC_PORT=50056
PAYMENT_GRPC_PORT=50057

# =========================
# URLs internas gRPC para API Gateway
# =========================
IDENTITY_GRPC_URL=identity-service:50051
FX_GRPC_URL=fx-service:50052
SUBSCRIPTION_GRPC_URL=subscription-service:50053
NOTIFICATION_GRPC_URL=notification-service:50054
CATALOG_GRPC_URL=catalog-service:50055
ENGAGEMENT_GRPC_URL=engagement-service:50056
PAYMENT_GRPC_URL=payment-gateway-service:50057

# =========================
# API Gateway / Web
# =========================
API_GATEWAY_PORT=3000
WEB_PORT=8080

# =========================
# Identity DB en GCP
# =========================
IDENTITY_DB_HOST=TU_IP_GCP_IDENTITY
IDENTITY_DB_PORT=5432
IDENTITY_DB_NAME=identity_db
IDENTITY_DB_USER=identity_user
IDENTITY_DB_PASSWORD=TU_PASSWORD_IDENTITY

# =========================
# Subscription DB en GCP
# =========================
SUBSCRIPTION_DB_HOST=TU_IP_GCP_SUBSCRIPTION
SUBSCRIPTION_DB_PORT=5432
SUBSCRIPTION_DB_NAME=subscription_db
SUBSCRIPTION_DB_USER=sa_sub_user
SUBSCRIPTION_DB_PASSWORD=TU_PASSWORD_SUBSCRIPTION
SUBSCRIPTION_DATABASE_URL=postgresql://sa_sub_user:TU_PASSWORD_SUBSCRIPTION@TU_IP_GCP_SUBSCRIPTION:5432/subscription_db

# =========================
# Catalog DB en GCP
# =========================
CATALOG_DB_HOST=TU_IP_GCP_CATALOG
CATALOG_DB_PORT=5432
CATALOG_DB_NAME=catalog_db
CATALOG_DB_USER=catalog_user
CATALOG_DB_PASSWORD=TU_PASSWORD_CATALOG
CATALOG_DATABASE_URL=postgresql://catalog_user:TU_PASSWORD_CATALOG@TU_IP_GCP_CATALOG:5432/catalog_db

# =========================
# Engagement DB en GCP
# =========================
ENGAGEMENT_DB_HOST=TU_IP_GCP_ENGAGEMENT
ENGAGEMENT_DB_PORT=5432
ENGAGEMENT_DB_NAME=engagement_db
ENGAGEMENT_DB_USER=engagement_user
ENGAGEMENT_DB_PASSWORD=TU_PASSWORD_ENGAGEMENT
ENGAGEMENT_DATABASE_URL=postgresql://engagement_user:TU_PASSWORD_ENGAGEMENT@TU_IP_GCP_ENGAGEMENT:5432/engagement_db

# =========================
# FX
# =========================
FX_CACHE_TTL=3600
FX_API_BASE_URL=https://api.frankfurter.dev/v2

# =========================
# Notification SMTP
# =========================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=TU_CORREO
SMTP_PASSWORD=TU_APP_PASSWORD
SMTP_FROM=TU_CORREO
SMTP_STARTTLS=true

# =========================
# Catalog provider
# =========================
ARCHIVE_METADATA_BASE_URL=https://archive.org/metadata
ARCHIVE_DOWNLOAD_BASE_URL=https://archive.org/download
ARCHIVE_IMAGE_BASE_URL=https://archive.org/services/img
ARCHIVE_MOVIE_TARGET=10
ARCHIVE_SERIES_TARGET=20
ARCHIVE_SERIES_EPISODE_LIMIT=20
ARCHIVE_MOVIE_IDENTIFIERS=charlie-chaplin-the-champion-1915,charliechaplin_theimmigrant_20190819,night_of_the_living_dead,TheGeneral,Nosferatu1922
ARCHIVE_SERIES_IDENTIFIER=BarbecueForTwo1960
ARCHIVE_SERIES_IDENTIFIERS=BarbecueForTwo1960,Popeye_forPresident,popeye-meets-ali-baba-1937,PopeyePopeyeTheSailorMeetsSindbadTheSailor1936,PopeyeAncientFistory,popeye-private-eye-popeye-1954,popeye-little-sweepea-1936,popeye-greek-mirthology-1954,popeye-i-dont-scare-1956,popeye-spree-lunch-1957
ARCHIVE_SERIES_EPISODE_IDENTIFIERS=
ARCHIVE_SERIES_TITLE=Serie Internet Archive
ARCHIVE_ALLOW_FALLBACK=false

# =========================
# Payment sandbox
# =========================
PAYMENT_PROVIDER_NAME=QuetxalPay Sandbox
PAYMENT_APPROVAL_DELAY_MS=500

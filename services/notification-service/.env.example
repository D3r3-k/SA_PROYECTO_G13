# Optional SMTP configuration. If set, notifications will be sent via SMTP.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=notifications@example.com

# Database (if used)
DATABASE_URL=postgresql://sa_user:sa_pass@postgres:5432/sa_db
# Notification service environment example
NOTIFICATION_PROVIDER=console
FROM_EMAIL=no-reply@example.com
LOG_LEVEL=INFO
# Example: smtp, sendgrid, mailgun, console
# If using SMTP, set SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASS

# URL publica del Ingress de GKE o dominio de la nube. No usar localhost para calificacion.
LOCUST_HOST=http://34.000.000.000

# Carga ligera recomendada para no saturar el cluster e2-small durante la demo.
LOCUST_USERS=20
LOCUST_SPAWN_RATE=2
LOCUST_RUN_TIME=3m

# Datos de prueba. Puede usar LOCUST_USERS_CSV como secret en GitHub Actions.
LOCUST_USERS_FILE=tests/load/users.example.csv
LOCUST_AUTO_SELECT_PROFILE=true
LOCUST_STRICT_AUTH=true
LOCUST_ENABLE_WS=true

# Opcional: fijar contenidos criticos. Si queda vacio, Locust intenta descubrirlos desde /api/catalog.
LOCUST_CONTENT_IDS=
LOCUST_SEARCH_TERMS=accion,drama,comedia,familia,aventura

# Alternativa sin CSV para ejecucion local contra nube.
LOCUST_PREMIUM_EMAIL=
LOCUST_PREMIUM_PASSWORD=
LOCUST_STANDARD_EMAIL=
LOCUST_STANDARD_PASSWORD=
LOCUST_BASIC_EMAIL=
LOCUST_BASIC_PASSWORD=
LOCUST_ADMIN_EMAIL=
LOCUST_ADMIN_PASSWORD=

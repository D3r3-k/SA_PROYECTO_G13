# URL publica del ambiente cloud. En develop suele ser la IP publica de la VM frontend.
LOCUST_HOST=https://34.71.199.200

# Modo de ejecucion:
# - route-check: no requiere usuarios reales; valida rutas y respuestas esperadas 200/401/403/404 controlado.
# - full-flow: requiere usuarios reales de prueba; ejecuta login, perfil, catalogo, recomendaciones, descarga y Watch Party.
# LOCUST_MODE=route-check
LOCUST_MODE=full-flow

# Carga ligera recomendada para no afectar la demo.
LOCUST_USERS=20
LOCUST_SPAWN_RATE=2
LOCUST_RUN_TIME=3m

# Solo necesario para full-flow.
LOCUST_USERS_FILE=tests/load/users.example.csv
LOCUST_USERS_CSV=
LOCUST_AUTO_SELECT_PROFILE=true
LOCUST_STRICT_AUTH=true
LOCUST_ENABLE_WS=false

# Opcional. Si se omite, Locust intenta descubrir contenido desde /api/catalog en full-flow.
LOCUST_CONTENT_IDS=
LOCUST_SEARCH_TERMS=accion,drama,comedia,familia,aventura

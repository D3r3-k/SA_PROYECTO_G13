# Ejecucion local contra ambiente release.
# Usar URL completa, por ejemplo http://34.10.20.30 o https://release.midominio.com.
LOCUST_HOST=http://IP_RELEASE

# Tambien puede usarse solo IP:
# RELEASE_IP=34.10.20.30

# Flujo recomendado para release: usuarios reales de prueba desde el CSV.
LOCUST_MODE=full-flow
LOCUST_USERS_FILE=tests/load/users.example.csv

# Carga ligera para no afectar la demo/calificacion.
LOCUST_USERS=20
LOCUST_SPAWN_RATE=2
LOCUST_RUN_TIME=3m

# Seguridad del flujo autenticado.
LOCUST_AUTO_SELECT_PROFILE=true
LOCUST_STRICT_AUTH=true

# Se deja false por defecto en local para evitar fallos de proxy/firewall con WebSocket.
LOCUST_ENABLE_WS=false

# Opcional. Si se omite, Locust descubre contenido desde /api/catalog.
LOCUST_CONTENT_IDS=
LOCUST_SEARCH_TERMS=accion,drama,comedia,familia,aventura